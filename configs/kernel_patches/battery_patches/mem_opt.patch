From: Antigravity <antigravity@google.com>
Date: Mon, 20 Apr 2026 21:30:00 +0600
Subject: [PATCH] battery: optimize memory reclaim efficiency

This version uses minimal context to improve compatibility across kernel versions.

---
 mm/vmscan.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/mm/vmscan.c b/mm/vmscan.c
--- a/mm/vmscan.c
+++ b/mm/vmscan.c
@@ -20,6 +20,11 @@
 #include <linux/mman.h>
 #include <linux/pagemap.h>
 
+/* Battery optimization: Reduce kswapd wakeups on light pressure */
+#ifndef CONFIG_KSWAPD_SLEEP_DEFERRED_MS
+#define KSWAPD_SLEEP_DEFERRED_MS 1000
+#endif
+
 /*
  * The amount of pages we want to scan in one go.
  */
@@ -3480,11 +3485,16 @@
 	prepare_to_wait(&pgdat->kswapd_wait, &wait, TASK_INTERRUPTIBLE);
 	if (prepare_kswapd_sleep(pgdat, reclaim_order, classzone_idx)) {
 		/*
-		 * No actually, we should just stay awake.
+		 * Battery: Wait a bit before fully waking up kswapd again 
+		 * to avoid rapid sleep/wake cycles that consume power.
 		 */
+		if (!static_branch_unlikely(&lru_gen_caps[LRU_GEN_CORE])) {
+			msleep_interruptible(10);
+		}
+
 		finish_wait(&pgdat->kswapd_wait, &wait);
 		return;
 	}
-- 
