From: Antigravity <antigravity@google.com>
Date: Mon, 20 Apr 2026 21:32:00 +0600
Subject: [PATCH] battery: silence non-essential kernel logging

Reduces logging overhead to save CPU cycles and power.

---
 include/linux/printk.h | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/include/linux/printk.h b/include/linux/printk.h
--- a/include/linux/printk.h
+++ b/include/linux/printk.h
@@ -10,6 +10,16 @@
 
 #include <linux/init.h>
 #include <linux/kern_levels.h>
+
+/* Battery optimization: Silence low-priority logging */
+#ifdef CONFIG_OP_BATTERY_OPT
+#define pr_debug_silent(fmt, ...) \
+	({ if (0) printk(KERN_DEBUG pr_fmt(fmt), ##__VA_ARGS__); 0; })
+#undef pr_debug
+#define pr_debug pr_debug_silent
+#undef dev_dbg
+#define dev_dbg(dev, fmt, ...) do { (void)(dev); if (0) printk(KERN_DEBUG pr_fmt(fmt), ##__VA_ARGS__); } while (0)
+#endif
 
 #include <linux/linkage.h>
 #include <linux/cache.h>
